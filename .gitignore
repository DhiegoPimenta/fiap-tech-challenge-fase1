# Jupyter Notebooks
# ─────────────────────────────────────────────
.ipynb_checkpoints/

# ─────────────────────────────────────────────
# Dados (não versionar arquivos grandes)
# ─────────────────────────────────────────────
data/raw/*.csv
data/raw/*.zip
data/raw/*.xlsx
data/processed/*.csv
# Os modelos treinados também podem ser grandes
# Se ultrapassar 100MB, usar Git LFS ou não versionar
app/models/artifacts/*.h5
app/models/artifacts/*.pkl

# ─────────────────────────────────────────────
